# ─────────────────────────────────────────────────────────────────────────────
# Proyekto API — Environment Variables
#
# For local dev (non-Docker):   copy to apps/api/.env.local
# For Render deployment:        paste each key into the Render dashboard
#                               under Environment → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (Neon) ─────────────────────────────────────────────────────────
# Neon console → your project → Connection string (pooled)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true&connection_limit=5

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# Upstash console → your database → Details → rediss:// connection string
REDIS_URL=rediss://default:password@host:port

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Must be two DIFFERENT long random strings.
# Generate: openssl rand -base64 32
JWT_ACCESS_SECRET=replace-with-openssl-rand-base64-32
JWT_REFRESH_SECRET=replace-with-a-different-openssl-rand-base64-32

# ── CORS ──────────────────────────────────────────────────────────────────────
# The deployed Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app

# ── E2E Test Cleanup ──────────────────────────────────────────────────────────
# Used only by DELETE /test01/test_cleanup — set to any secret string
TEST_SECRET=replace-with-any-secret-string

# ── Runtime ───────────────────────────────────────────────────────────────────
# Render sets PORT automatically. NODE_ENV is set to production by the Dockerfile.
# Do NOT set these manually on Render — Render manages them.
# PORT=8000
# NODE_ENV=production
