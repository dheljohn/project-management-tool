generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
  
}

enum TaskStatus {
  Todo
  In_Progress
  Done
}

model Member {
  id         Int     @id @default(autoincrement())
  user_id    String  @unique
  email      String  @unique
  password   String

  projects   Project[]
  changeLogs ChangeLog[]
}

model Project {
  id          Int      @id @default(autoincrement())

  name        String
  description String?

  ownerId     Int

  owner       Member   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  tasks       Task[] 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id          Int        @id @default(autoincrement())

  title       String
  description String?
  status      TaskStatus @default(Todo)

  changelogs  ChangeLog[]

  projectId   Int
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model ChangeLog {
  id          Int        @id @default(autoincrement())
  taskId      Int
  task        Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  username    String     
  member      Member     @relation(fields: [username], references: [user_id], onDelete: Cascade)
  field       String     // "status" | "title" | "description"
  oldValue    String?
  newValue    String?
  remark      String?
  createdAt   DateTime   @default(now())
}