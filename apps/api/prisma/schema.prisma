generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Member {
  id         Int         @id @default(autoincrement())
  user_id    String      @unique
  email      String      @unique
  password   String
  changeLogs ChangeLog[]
  projects   Project[]
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ownerId     Int
  owner       Member   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tasks       Task[]
  wipLimit    Int?
}

model Task {
  id          Int         @id @default(autoincrement())
  title       String
  description String?
  status      TaskStatus  @default(Todo)
  projectId   Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  priority    Priority    @default(Medium)
  changelogs  ChangeLog[]
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ChangeLog {
  id        Int      @id @default(autoincrement())
  taskId    Int
  field     String
  oldValue  String?
  newValue  String?
  remark    String?
  createdAt DateTime @default(now())
  username  String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  member    Member   @relation(fields: [username], references: [user_id], onDelete: Cascade)
}

enum TaskStatus {
  Todo
  In_Progress
  Done
}

enum Priority {
  Critical
  High
  Medium
  Low
}
