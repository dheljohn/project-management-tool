# ─────────────────────────────────────────────────────────────────────────────
# Proyekto — Local Docker Compose Environment
#
# Copy this file to .env and fill in the values.
# This file is used by docker-compose.yaml for BOTH the api and web containers.
#
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (Neon) ─────────────────────────────────────────────────────────
# Get this from: https://console.neon.tech → your project → Connection string
# Use the "pooled" connection string with pgbouncer=true for production.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true&connection_limit=5

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# Get this from: https://console.upstash.com → your database → REST API → rediss:// URL
REDIS_URL=rediss://default:password@host:port

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate each with: openssl rand -base64 32
# Use DIFFERENT values for access and refresh — they must not be interchangeable.
JWT_ACCESS_SECRET=replace-with-openssl-rand-base64-32-output
JWT_REFRESH_SECRET=replace-with-a-different-openssl-rand-base64-32-output

# ── CSRF / Test ───────────────────────────────────────────────────────────────
TEST_SECRET=replace-with-a-secret-used-by-e2e-test-cleanup-endpoint

# ── CORS (API → Frontend) ─────────────────────────────────────────────────────
# For local Docker: http://localhost:3000
# For production pointing at Vercel: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# ── Frontend (web container) ──────────────────────────────────────────────────
# For local Docker: http://localhost:8000
# For production pointing at Render: https://your-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000
