# ─────────────────────────────────────────────────────────────────────────────
# Proyekto — Local Docker Compose / local dev environment
#
# Copy this file to .env and fill in all values:
#   cp .env.example .env
#
# This file is loaded automatically by docker-compose.
# It is also used by apps/api directly when running `npm run dev` locally
# (via `dotenv-cli` in the dev script).

DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true&connection_limit=5

REDIS_URL=rediss://default:password@host:port

JWT_ACCESS_SECRET=replace_with_openssl_rand_base64_32

JWT_REFRESH_SECRET=replace_with_a_different_openssl_rand_base64_32

TEST_SECRET=replace_with_any_secret_string

# good to go 
FRONTEND_URL=http://localhost:3000
DOCKER_API=http://api:8000 #for docker setup
API_URL=http://localhost:8000
