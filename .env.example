# ─────────────────────────────────────────────────────────────────────────────
# Proyekto — Local Docker Compose / local dev environment
#
# Copy this file to .env and fill in all values:
#   cp .env.example .env
#
# This file is loaded automatically by docker-compose.
# It is also used by apps/api directly when running `npm run dev` locally
# (via `dotenv-cli` in the dev script).
#
# NEVER commit .env — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (Neon) ─────────────────────────────────────────────────────────
# Neon dashboard → your project → Connection Details → Connection string
# Use the POOLED string (includes pgbouncer=true) for production/Docker.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true&connection_limit=5

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# Upstash console → your database → Details → rediss:// connection string
REDIS_URL=rediss://default:password@host:port

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Must be two DIFFERENT long random strings.
# Generate each with: openssl rand -base64 32
# ACCESS and REFRESH secrets must not be the same value.
JWT_ACCESS_SECRET=replace_with_openssl_rand_base64_32
JWT_REFRESH_SECRET=replace_with_a_different_openssl_rand_base64_32

# ── E2E Test Cleanup ──────────────────────────────────────────────────────────
# Used by DELETE /test01/test_cleanup in the API — set to any secret string.
TEST_SECRET=replace_with_any_secret_string

# ── CORS — which frontend the API allows ──────────────────────────────────────
# Local Docker Compose: http://localhost:3000
# When running API locally but using deployed Vercel frontend: https://proyekto-blue.vercel.app
FRONTEND_URL=http://localhost:3000

# ── Frontend API URL — baked into the Next.js client bundle at build time ─────
# Local Docker Compose: http://localhost:8000
# When running web locally but using deployed Render API: https://proyekto.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000
